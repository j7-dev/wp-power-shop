{
	"name": "power-shop",
	"private": false,
	"version": "3.0.17",
	"type": "module",
	"scripts": {
		"bootstrap": "composer install --no-interaction",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"format": "prettier-eslint --write \"js/src/**/*.tsx\"",
		"lint:php": "phpcbf && phpcs inc --report=full -v && phpstan analyze inc --memory-limit=4096M",
		"lint:ts": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js \"js/src/**/*.{ts,tsx}\" --ext .ts,.tsx --fix --rule \"no-unused-vars: off\"",
		"release": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs",
		"release:build-only": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs --build-only",
		"release:patch": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs",
		"release:minor": "env-cmd -f ./.env release-it minor --ci --verbose --config ./release/.release-it.cjs",
		"release:major": "env-cmd -f ./.env release-it major --ci --verbose --config ./release/.release-it.cjs",
		"zip": "env-cmd -f ./.env node ./release/zip.cjs",
		"create:release": "env-cmd -f ./.env node ./release/create-release.cjs",
		"sync:version": "wp-update-project-version -s package.json -p plugin.php",
		"replace-string": "node ./replace-string.cjs",
		"i18n": "wp i18n make-pot . languages/power_shop.pot",
		"i18n:commit": "pnpm i18n && git add . && git commit --amend --no-edit"
	},
	"dependencies": {
		"@ant-design/cssinjs": "1.23.0",
		"@ant-design/icons": "^6.0.0",
		"@ant-design/plots": "2.5.0",
		"@ant-design/pro-editor": "^1.3.0",
		"@blocknote/code-block": "^0.31.2",
		"@blocknote/core": "0.30.0",
		"@blocknote/mantine": "0.30.0",
		"@blocknote/react": "0.30.0",
		"@refinedev/antd": "5.46.1",
		"@refinedev/cli": "2.16.46",
		"@refinedev/core": "4.57.9",
		"@refinedev/inferencer": "4.7.1",
		"@refinedev/react-router": "^1.0.1",
		"@refinedev/simple-rest": "5.0.10",
		"@tanstack/query-core": "^4.39.2",
		"@tanstack/react-query": "4.39.2",
		"@uidotdev/usehooks": "^2.4.1",
		"antd": "5.26.1",
		"antd-img-crop": "4.25.0",
		"antd-style": "^3.7.1",
		"antd-toolkit": "1.3.221",
		"axios": "^1.10.0",
		"dayjs": "1.11.13",
		"echarts": "^5.6.0",
		"immer": "^10.1.1",
		"jotai": "^2.12.5",
		"lodash-es": "4.17.21",
		"nanoid": "^5.1.5",
		"query-string": "^9.2.1",
		"react": "^18.3.1",
		"react-countup": "^6.5.3",
		"react-dom": "^18.3.1",
		"react-icons": "^5.5.0",
		"react-router": "^7.6.2",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@kucrut/vite-for-wp": "^0.11.6",
		"@release-it/bumper": "^7.0.5",
		"@rollup/plugin-alias": "^5.1.1",
		"@soderlind/wp-project-version-sync": "^2.0.2",
		"@tanstack/react-query-devtools": "4.36.1",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^20.12.3",
		"@types/react": "^18.2.15",
		"@types/react-dom": "18.3.7",
		"@typescript-eslint/eslint-plugin": "^7.15.0",
		"@typescript-eslint/parser": "^7.15.0",
		"@vitejs/plugin-react": "^4.6.0",
		"@wordpress/element": "^6.27.0",
		"@wordpress/eslint-plugin": "^17.11.0",
		"@wordpress/html-entities": "^4.27.0",
		"@wordpress/i18n": "^6.0.0",
		"adm-zip": "^0.5.12",
		"archiver": "^7.0.1",
		"autoprefixer": "^10.4.19",
		"change-case-all": "^2.1.0",
		"daisyui": "^4.12.23",
		"env-cmd": "^10.1.0",
		"esbuild": "0.18.20",
		"eslint": "^8.57.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-prettier": "^9.1.0",
		"eslint-config-standard-with-typescript": "^43.0.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-n": "^16.6.2",
		"eslint-plugin-prettier": "^5.5.0",
		"eslint-plugin-promise": "^6.1.1",
		"eslint-plugin-react": "^7.34.3",
		"eslint-plugin-react-hooks": "^4.6.2",
		"glob": "^10.4.5",
		"postcss": "^8.4.39",
		"postcss-import": "^16.1.0",
		"postcss-nesting": "^12.1.5",
		"prettier": "^3.5.3",
		"prettier-eslint": "^16.3.0",
		"prettier-eslint-cli": "^8.0.1",
		"prettier-plugin-multiline-arrays": "^4.1.3",
		"release-it": "^19.0.3",
		"release-it-pnpm": "^4.6.6",
		"replace-in-file": "^7.1.0",
		"rollup-plugin-terser": "^7.0.2",
		"sass": "^1.77.6",
		"tailwindcss": "^3.4.4",
		"typescript": "5.5.4",
		"typescript-eslint": "^7.5.0",
		"vite": "^6.3.5",
		"vite-plugin-live-reload": "^3.0.3",
		"vite-plugin-optimizer": "^1.4.3",
		"vite-tsconfig-paths": "^4.3.2",
		"yargs": "^17.7.2"
	},
	"packageManager": "pnpm@10.32.0"
}
