{
	"mcpServers": {
		"playwright": {
			"tools": [
				"*"
			],
			"type": "local",
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest"
			]
		},
		"serena": {
			"tools": [
				"*"
			],
			"type": "local",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--help"
			]
		}
	}
}